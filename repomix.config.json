{
  "output": {
    "filePath": "repomix-output.xml",
    "style": "xml",
    "compress": true,
    "removeComments": false,
    "removeEmptyLines": true,
    "showLineNumbers": true
  },
  "ignore": {
    "customPatterns": [
      "node_modules/**",
      "dist/**",
      "build/**",
      ".venv/**",
      "venv/**",
      "__pycache__/**",
      ".git/**",
      "*.log",
      "*.sqlite",
      "*.db",
      ".env",
      ".env.*",
      "coverage/**",
      ".pytest_cache/**",
      ".mypy_cache/**",
      ".ruff_cache/**"
    ]
  }
}
